[
  { "zh": "你好!", "pinyin": "nǐ hǎo!", "en": "Hello!", "cz": "Ahoj!" },
  { "zh": "你好吗?", "pinyin": "nǐ hǎo ma?", "en": "How are you?", "cz": "Jak se máš?" },
  { "zh": "我很好。", "pinyin": "wǒ hěn hǎo.", "en": "I'm fine.", "cz": "Mám se dobře." },
  { "zh": "谢谢!", "pinyin": "xiè xiè!", "en": "Thank you!", "cz": "Děkuji!" },
  { "zh": "不客气。", "pinyin": "bù kè qi.", "en": "You're welcome.", "cz": "Není zač." },
  { "zh": "对不起。", "pinyin": "duì bu qǐ.", "en": "Sorry.", "cz": "Promiň." },
  { "zh": "没关系。", "pinyin": "méi guān xi.", "en": "It's okay.", "cz": "Nevadí." },
  { "zh": "再见!", "pinyin": "zài jiàn!", "en": "Goodbye!", "cz": "Na shledanou!" },
  { "zh": "我是学生。", "pinyin": "wǒ shì xué sheng.", "en": "I am a student.", "cz": "Jsem student." },
  { "zh": "我是中国人。", "pinyin": "wǒ shì zhōng guó rén.", "en": "I am Chinese.", "cz": "Jsem Číňan." },
  { "zh": "你是老师吗?", "pinyin": "nǐ shì lǎo shī ma?", "en": "Are you a teacher?", "cz": "Jsi učitel?" },
  { "zh": "他叫什么?", "pinyin": "tā jiào shén me?", "en": "What's his name?", "cz": "Jak se jmenuje?" },
  { "zh": "我叫小明。", "pinyin": "wǒ jiào xiǎo míng.", "en": "My name is Xiao Ming.", "cz": "Jmenuji se Siao-ming." },
  { "zh": "这是什么?", "pinyin": "zhè shì shén me?", "en": "What is this?", "cz": "Co je to?" },
  { "zh": "这是我的书。", "pinyin": "zhè shì wǒ de shū.", "en": "This is my book.", "cz": "To je moje kniha." },
  { "zh": "那是他的。", "pinyin": "nà shì tā de.", "en": "That is his.", "cz": "To je jeho." },
  { "zh": "我有一个朋友。", "pinyin": "wǒ yǒu yí ge péng you.", "en": "I have a friend.", "cz": "Mám kamaráda." },
  { "zh": "你有几个?", "pinyin": "nǐ yǒu jǐ ge?", "en": "How many do you have?", "cz": "Kolik jich máš?" },
  { "zh": "今天星期一。", "pinyin": "jīn tiān xīng qī yī.", "en": "Today is Monday.", "cz": "Dnes je pondělí." },
  { "zh": "现在几点?", "pinyin": "xiàn zài jǐ diǎn?", "en": "What time is it?", "cz": "Kolik je hodin?" },
  { "zh": "现在三点。", "pinyin": "xiàn zài sān diǎn.", "en": "It's three o'clock.", "cz": "Jsou tři hodiny." },
  { "zh": "我爱你。", "pinyin": "wǒ ài nǐ.", "en": "I love you.", "cz": "Miluji tě." },
  { "zh": "我喜欢你。", "pinyin": "wǒ xǐ huan nǐ.", "en": "I like you.", "cz": "Mám tě rád." },
  { "zh": "我想吃饭。", "pinyin": "wǒ xiǎng chī fàn.", "en": "I want to eat.", "cz": "Chci jíst." },
  { "zh": "我不喝茶。", "pinyin": "wǒ bù hē chá.", "en": "I don't drink tea.", "cz": "Nepiju čaj." },
  { "zh": "请喝水。", "pinyin": "qǐng hē shuǐ.", "en": "Please drink water.", "cz": "Prosím napij se vody." },
  { "zh": "我会说汉语。", "pinyin": "wǒ huì shuō hàn yǔ.", "en": "I can speak Chinese.", "cz": "Umím čínsky." },
  { "zh": "你会说英语吗?", "pinyin": "nǐ huì shuō yīng yǔ ma?", "en": "Can you speak English?", "cz": "Umíš anglicky?" },
  { "zh": "我不会。", "pinyin": "wǒ bú huì.", "en": "I can't.", "cz": "Neumím." },
  { "zh": "他在家。", "pinyin": "tā zài jiā.", "en": "He is at home.", "cz": "Je doma." },
  { "zh": "我在学校。", "pinyin": "wǒ zài xué xiào.", "en": "I am at school.", "cz": "Jsem ve škole." },
  { "zh": "你去哪儿?", "pinyin": "nǐ qù nǎr?", "en": "Where are you going?", "cz": "Kam jdeš?" },
  { "zh": "我去北京。", "pinyin": "wǒ qù běi jīng.", "en": "I'm going to Beijing.", "cz": "Jdu do Pekingu." },
  { "zh": "这个多少钱?", "pinyin": "zhè ge duō shao qián?", "en": "How much is this?", "cz": "Kolik to stojí?" },
  { "zh": "一百块。", "pinyin": "yì bǎi kuài.", "en": "One hundred kuai.", "cz": "Sto juanů." },
  { "zh": "太贵了!", "pinyin": "tài guì le!", "en": "Too expensive!", "cz": "Moc drahé!" },
  { "zh": "便宜一点。", "pinyin": "pián yi yì diǎn.", "en": "A bit cheaper.", "cz": "Trochu levněji." },
  { "zh": "我不买。", "pinyin": "wǒ bù mǎi.", "en": "I'm not buying.", "cz": "Nekoupím." },
  { "zh": "天气很好。", "pinyin": "tiān qì hěn hǎo.", "en": "The weather is nice.", "cz": "Počasí je hezké." },
  { "zh": "今天很冷。", "pinyin": "jīn tiān hěn lěng.", "en": "Today is cold.", "cz": "Dnes je chladno." },
  { "zh": "明天下雨。", "pinyin": "míng tiān xià yǔ.", "en": "Tomorrow it will rain.", "cz": "Zítra bude pršet." },
  { "zh": "我很累。", "pinyin": "wǒ hěn lèi.", "en": "I'm tired.", "cz": "Jsem unavený." },
  { "zh": "我想睡觉。", "pinyin": "wǒ xiǎng shuì jiào.", "en": "I want to sleep.", "cz": "Chci spát." },
  { "zh": "你几岁?", "pinyin": "nǐ jǐ suì?", "en": "How old are you?", "cz": "Kolik ti je let?" },
  { "zh": "我二十岁。", "pinyin": "wǒ èr shí suì.", "en": "I'm twenty.", "cz": "Je mi dvacet." },
  { "zh": "你家有几个人?", "pinyin": "nǐ jiā yǒu jǐ ge rén?", "en": "How many people in your family?", "cz": "Kolik lidí je ve tvé rodině?" },
  { "zh": "我有一个妹妹。", "pinyin": "wǒ yǒu yí ge mèi mei.", "en": "I have a little sister.", "cz": "Mám mladší sestru." },
  { "zh": "他是我爸爸。", "pinyin": "tā shì wǒ bà ba.", "en": "He is my dad.", "cz": "To je můj táta." },
  { "zh": "妈妈在做饭。", "pinyin": "mā ma zài zuò fàn.", "en": "Mom is cooking.", "cz": "Máma vaří." },
  { "zh": "我的狗很可爱。", "pinyin": "wǒ de gǒu hěn kě ài.", "en": "My dog is cute.", "cz": "Můj pes je roztomilý." },
  { "zh": "猫在桌子上。", "pinyin": "māo zài zhuō zi shàng.", "en": "The cat is on the table.", "cz": "Kočka je na stole." },
  { "zh": "我喜欢中国菜。", "pinyin": "wǒ xǐ huan zhōng guó cài.", "en": "I like Chinese food.", "cz": "Mám rád čínské jídlo." },
  { "zh": "米饭很好吃。", "pinyin": "mǐ fàn hěn hǎo chī.", "en": "The rice is delicious.", "cz": "Rýže je dobrá." },
  { "zh": "请给我一杯水。", "pinyin": "qǐng gěi wǒ yì bēi shuǐ.", "en": "Please give me a glass of water.", "cz": "Dej mi sklenici vody." },
  { "zh": "老师在教室里。", "pinyin": "lǎo shī zài jiào shì lǐ.", "en": "The teacher is in the classroom.", "cz": "Učitel je ve třídě." },
  { "zh": "学生在写字。", "pinyin": "xué sheng zài xiě zì.", "en": "Students are writing characters.", "cz": "Studenti píšou znaky." },
  { "zh": "我听不懂。", "pinyin": "wǒ tīng bu dǒng.", "en": "I don't understand.", "cz": "Nerozumím." },
  { "zh": "请慢一点说。", "pinyin": "qǐng màn yì diǎn shuō.", "en": "Please speak slower.", "cz": "Mluv prosím pomaleji." },
  { "zh": "请再说一遍。", "pinyin": "qǐng zài shuō yí biàn.", "en": "Please say it again.", "cz": "Řekni to prosím znovu." },
  { "zh": "这个字怎么读?", "pinyin": "zhè ge zì zěn me dú?", "en": "How do you read this character?", "cz": "Jak se tento znak čte?" }
]
